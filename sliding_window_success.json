{
  "configuration": {
    "name": "SLIDING WINDOW SUCCESS: 10 Note Demonstration",
    "description": "Clear chromatic ascending pattern with voice 2 parallel motion, extended MIDI range",
    "num_voices": 2,
    "sequence_length": 10,
    "pitch_range": [36, 128],
    "rhythm_values": [1, 2, 4],
    "time_signature": "3/4"
  },
  "rules": [
    {
      "id": "voice1_starts_c4",
      "rule_id": "voice1_starts_c4",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[0] == 60",
      "description": "Rule 1: (INDEX) Voice 1 starts C4"
    },
    {
      "id": "voice1_chromatic_up",
      "rule_id": "voice1_chromatic_up",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "sliding_window",
      "pattern_offsets": [0, 1],
      "constraint": "voice[0].pitch[i+1] == voice[0].pitch[i] + 1",
      "description": "Rule 2: (SLIDING WINDOW) Voice 1 chromatic ascent +1 semitone per step"
    },
    {
      "id": "voice2_parallel",
      "rule_id": "voice2_parallel",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[1].pitch[i] == voice[0].pitch[i] - 12",
      "description": "Rule 3: (FOR_ALL_POSITIONS) Voice 2 exactly 1 octave below voice 1"
    }
  ]
}
