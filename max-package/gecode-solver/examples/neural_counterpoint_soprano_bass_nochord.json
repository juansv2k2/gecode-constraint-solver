  "search_options": {
    "engine": "dfs",
    "enable_metric_engine": 0,
    "random_seed": 0,
    "timeout_ms": 30000,
    "branching": "first_fail",
    "value_order": "neural",
    "neural_weights_file": "weights/harmonic_weights.json",
    "neural_temperature": 0.3
