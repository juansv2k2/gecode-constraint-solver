  "export_json": false,
  "export_txt": false,
  "export_xml": true,
  "file_name": "output/neural_counterpoint_soprano_bass",
  "rules": [
    {
      "id": "soprano_above_bass",
      "rule_type": "r-pitch-pitch",
      "constraint": "voice_above",
      "target_voices": [
        0,
        1
      ],
      "description": "Hard: soprano strictly above bass at every position"
    },
    {
      "id": "consonant_harmony",
      "rule_type": "r-pitch-pitch",
      "constraint": "interval_class",
      "parameters": [
        0,
        3,
        4,
        7,
        8,
        9
      ],
      "target_voices": [
        0,
        1
      ],
      "enabled": false,
      "description": "Disabled: was masking neural harmonic signal. Soft version (soft_consonant_harmony) still applies as a heuristic."
    },
    {
      "id": "max_spacing_two_octaves",
      "rule_type": "r-pitch-pitch",
      "constraint": "max_interval",
      "parameters": [
        24
      ],
      "target_voices": [
        0,
        1
      ],
      "description": "Hard: voices may not be more than two octaves (24 semitones) apart"
    },
    {
      "id": "soprano_max_leap_fifth",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_voices",
      "pattern_offsets": [
        0,
        1
      ],
      "constraint": "abs(voice[v].pitch[i+1] - voice[v].pitch[i]) <= 7",
      "target_voices": [
        0
      ],
      "target_component": "pitch",
      "description": "Hard: soprano max leap P5 (7 semitones) -- leaves ~8-12 candidates per step for the neural scorer"
    },
    {
      "id": "soprano_no_adjacent_repeat",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_voices",
      "pattern_offsets": [
        0,
        1
      ],
      "constraint": "voice[v].pitch[i] != voice[v].pitch[i+1]",
      "target_voices": [
        0
      ],
      "target_component": "pitch",
      "heuristic": true,
      "description": "Soft: prefer no immediately repeated pitches in soprano (was hard \u2014 made soft so neural model can hold chord tones)"
    },
    {
      "id": "isorhythm_voices",
      "rule_type": "r-rhythm-rhythm",
      "constraint": "isorhythm",
      "target_voices": [
        0,
        1
      ],
      "description": "Hard: both voices share identical rhythm values"
    },
    {
      "id": "no_simultaneous_rests",
      "rule_type": "r-rhythm-rhythm",
      "constraint": "no_simultaneous_rests",
      "target_voices": [
        0,
        1
      ],
      "description": "Hard: at least one voice sounding at every position"
    },
    {
      "id": "soft_consonant_harmony",
      "rule_type": "r-pitch-pitch",
      "constraint": "interval_class",
      "parameters": [
        0,
        3,
        4,
        7,
        8,
        9
      ],
      "target_voices": [
        0,
        1
      ],
      "heuristic": true,
      "description": "Soft: prefer consonant intervals -- never rejects, only ranks consonant options higher"
    },
    {
      "id": "soft_no_parallel_fifths",
      "rule_type": "r-pitch-pitch",
      "constraint": "no_consecutive_fifths",
      "target_voices": [
        0,
        1
      ],
      "heuristic": true,
      "description": "Soft: prefer to avoid parallel fifths"
    },
    {
      "id": "soft_no_parallel_octaves",
      "rule_type": "r-pitch-pitch",
      "constraint": "no_consecutive_octaves",
      "target_voices": [
        0,
        1
      ],
      "heuristic": true,
      "description": "Soft: prefer to avoid parallel octaves"
    },
    {
      "id": "prefer_perfect_on_downbeats",
      "rule_type": "r-pitch-pitch",
      "constraint": "interval_class",
      "parameters": [
        0,
        7
      ],
      "indices": [
        0,
        4,
        8,
        12,
        16,
        20,
        24,
        28,
        32,
        36,
        40,
        44,
        48,
        52,
        56,
        60
      ],
      "target_voices": [
        0,
        1
      ],
      "heuristic": true,
      "description": "Soft: prefer perfect consonances on every downbeat (every 4th position)"
    },
    {
      "id": "prefer_contrary_motion",
      "rule_type": "r-pitch-pitch",
      "constraint": "contrary_motion",
      "target_voices": [
        0,
        1
      ],
      "heuristic": true,
      "description": "Soft: prefer contrary motion between voices"
    }
  ],
