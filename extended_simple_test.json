{
  "configuration": {
    "name": "Extended Range Simple Test",
    "description": "Test if extended domain works with basic constraints",
    "num_voices": 2,
    "sequence_length": 3,
    "pitch_range": [36, 128],
    "rhythm_values": [1, 2, 4],
    "time_signature": "3/4"
  },
  "rules": [
    {
      "id": "voice1_starts_c4",
      "rule_id": "voice1_starts_c4",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[0] == 60",
      "description": "Rule 1: Voice 1 starts with C4"
    },
    {
      "id": "voice2_below",
      "rule_id": "voice2_below",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[1].pitch[i] == voice[0].pitch[i] - 7",
      "description": "Rule 3: Voice 2 is exactly 7 semitones below voice 1"
    }
  ]
}
