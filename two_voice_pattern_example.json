{
  "configuration": {
    "name": "Two Voice Interval Pattern Example",
    "description": "Demonstrates voice relationships and interval patterns",
    "num_voices": 2,
    "sequence_length": 6,
    "pitch_range": [60, 72],
    "rhythm_values": [1, 2, 4]
  },
  "rules": [
    {
      "rule_id": "voice1_range",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[i] >= 63",
      "description": "Voice 1: stays in upper range (E♭4+)"
    },
    {
      "rule_id": "voice2_below_voice1",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[1].pitch[i] <= voice[0].pitch[i] - 3",
      "description": "Voice 2: stays at least 3 semitones below voice 1"
    },
    {
      "rule_id": "voice2_range",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[1].pitch[i] >= 60",
      "description": "Voice 2: stays at C4 or above"
    }
  ]
}
