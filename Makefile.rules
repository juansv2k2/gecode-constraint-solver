# ClusterEngine Rules Interface System - Makefile
# Complete build system for the musical constraint rules

CXX = g++
CXXFLAGS = -std=c++17 -O3 -Wall -Wextra -I./src
LDFLAGS = -lpthread

# Source directories  
SRC_DIR = src

# Core rules system sources
RULES_CORE_SOURCES = \
	$(SRC_DIR)/cluster_engine_rules_implementation.cpp \
	$(SRC_DIR)/cluster_engine_musical_rules_implementation.cpp

# Test sources
RULES_TEST_SOURCES = $(SRC_DIR)/test_cluster_engine_rules.cpp

# Object files
RULES_CORE_OBJECTS = $(RULES_CORE_SOURCES:.cpp=.o)
RULES_TEST_OBJECTS = $(RULES_TEST_SOURCES:.cpp=.o)

# Targets
RULES_LIB = libcluster_rules.a
RULES_TEST_EXECUTABLE = test_cluster_rules

# Default target
all: $(RULES_LIB) $(RULES_TEST_EXECUTABLE)

# Build rules library
$(RULES_LIB): $(RULES_CORE_OBJECTS)
	@echo "Creating ClusterEngine Rules Interface library..."
	ar rcs $@ $^
	@echo "✓ Rules library created: $@"

# Build test executable
$(RULES_TEST_EXECUTABLE): $(RULES_TEST_OBJECTS) $(RULES_LIB)
	@echo "Building rules test suite..."
	$(CXX) $(CXXFLAGS) -o $@ $^ $(LDFLAGS)
	@echo "✓ Test executable created: $@"

# Compile source files
%.o: %.cpp
	@echo "Compiling $<..."
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Run comprehensive rule tests
test: $(RULES_TEST_EXECUTABLE)
	@echo ""
	@echo "🎵 Running ClusterEngine Rules Interface Tests..."
	@echo "================================================"
	./$(RULES_TEST_EXECUTABLE)

# Quick functionality test
quick-test: $(RULES_TEST_EXECUTABLE)
	@echo "Running quick rules functionality test..."
	timeout 30 ./$(RULES_TEST_EXECUTABLE) | head -20

# Performance profile
profile: $(RULES_TEST_EXECUTABLE)
	@echo ""
	@echo "🚀 Running Rules Performance Profile..."
	@echo "======================================"
	./$(RULES_TEST_EXECUTABLE) | grep -A 10 "Performance Results"

# Debug build
debug: CXXFLAGS += -g -DDEBUG -O0
debug: clean all

# Release build with maximum optimization
release: CXXFLAGS += -O3 -DNDEBUG -march=native
release: clean all

# Clean build artifacts
clean:
	@echo "Cleaning rules build artifacts..."
	rm -f $(SRC_DIR)/*.o $(RULES_LIB) $(RULES_TEST_EXECUTABLE)
	@echo "✓ Build artifacts cleaned"

# Static analysis
analyze:
	@echo "Running static analysis on rules system..."
	@if command -v cppcheck >/dev/null 2>&1; then \
		cppcheck --enable=all --std=c++17 $(RULES_CORE_SOURCES) $(RULES_TEST_SOURCES); \
	else \
		echo "⚠ cppcheck not found, skipping analysis"; \
	fi

# Code formatting  
format:
	@echo "Formatting rules source code..."
	@if command -v clang-format >/dev/null 2>&1; then \
		clang-format -i $(RULES_CORE_SOURCES) $(RULES_TEST_SOURCES) src/cluster_engine_rules.hh src/cluster_engine_musical_rules.hh; \
		echo "✓ Code formatted"; \
	else \
		echo "⚠ clang-format not found, skipping formatting"; \
	fi

# Documentation generation
docs:
	@echo "Generating rules system documentation..."
	@if command -v doxygen >/dev/null 2>&1; then \
		doxygen Doxyfile.rules 2>/dev/null || echo "⚠ Doxyfile.rules not found"; \
		echo "✓ Documentation generated (if configured)"; \
	else \
		echo "⚠ Doxygen not found, skipping documentation generation"; \
	fi

# Install headers for integration
install-headers:
	@echo "Installing rules headers for integration..."
	mkdir -p $(DESTDIR)/usr/include/cluster_engine
	cp src/cluster_engine_rules.hh $(DESTDIR)/usr/include/cluster_engine/
	cp src/cluster_engine_musical_rules.hh $(DESTDIR)/usr/include/cluster_engine/
	@echo "✓ Headers installed"

# Create development package
dev-package: release docs
	@echo "Creating development package..."
	mkdir -p cluster-engine-rules-dev/lib
	mkdir -p cluster-engine-rules-dev/include
	mkdir -p cluster-engine-rules-dev/examples
	mkdir -p cluster-engine-rules-dev/docs
	cp $(RULES_LIB) cluster-engine-rules-dev/lib/
	cp src/cluster_engine_rules.hh cluster-engine-rules-dev/include/
	cp src/cluster_engine_musical_rules.hh cluster-engine-rules-dev/include/
	cp $(RULES_TEST_EXECUTABLE) cluster-engine-rules-dev/examples/
	tar czf cluster-engine-rules-dev.tar.gz cluster-engine-rules-dev/
	rm -rf cluster-engine-rules-dev/
	@echo "✓ Development package created: cluster-engine-rules-dev.tar.gz"

# Integration readiness check
integration-ready: release test
	@echo ""
	@echo "🎵 ClusterEngine Rules Interface System - Integration Status"
	@echo "=========================================================="
	@echo "✓ Core Rules Interface: IMPLEMENTED"
	@echo "✓ Single Engine Rules: IMPLEMENTED"  
	@echo "✓ Dual Engine Rules: IMPLEMENTED"
	@echo "✓ Multi Engine Rules: IMPLEMENTED"
	@echo "✓ Musical Rule Factories: IMPLEMENTED"
	@echo "✓ Rule Compilation System: IMPLEMENTED"
	@echo "✓ Backtrack Route Management: IMPLEMENTED"
	@echo "✓ Performance optimized build: COMPLETE"
	@echo "✓ Comprehensive test suite: PASSED"
	@echo ""
	@echo "Status: READY FOR CLUSTERENGINE INTEGRATION!"
	@echo ""
	@echo "What's Available:"
	@echo "- Complete musical constraint rules system"
	@echo "- 20+ pre-built musical rule types"
	@echo "- Rule compilation and management framework"
	@echo "- Classical, jazz, and minimalist preset rule sets"
	@echo "- Real-time performance optimized"
	@echo "- Full backtrack route support for constraint propagation"
	@echo ""
	@echo "Next Integration Steps:"
	@echo "1. Integrate with ClusterEngineCore"
	@echo "2. Connect rule evaluation to search loop"
	@echo "3. Implement rule-driven domain reduction"
	@echo "4. Add real-time rule statistics and adaptation"

# Show available rule types
show-rules:
	@echo "ClusterEngine Rules Interface - Available Rule Types"
	@echo "=================================================="
	@echo "Single Engine Rules (Rhythm):"
	@echo "- No Repeated Durations"
	@echo "- Rhythmic Canon"
	@echo "- Accelerando/Ritardando"
	@echo "- Metric Accent"
	@echo ""
	@echo "Single Engine Rules (Pitch):"
	@echo "- No Repeated Pitches"
	@echo "- Stepwise Motion"
	@echo "- No Large Leaps"
	@echo "- Melodic Contour"
	@echo "- Pitch Range"
	@echo "- Scale Membership"
	@echo ""
	@echo "Two Engine Rules (Rhythm-Pitch):"
	@echo "- Strong Beat Emphasis"
	@echo "- Syncopation Avoidance"
	@echo "- Cadential Patterns"
	@echo "- Rest Placement"
	@echo ""
	@echo "Multi Engine Rules (Harmonic):"
	@echo "- No Parallel Perfect Intervals"
	@echo "- Consonant Harmonies"
	@echo "- Voice Leading"
	@echo "- No Voice Crossing"
	@echo "- Chord Membership"
	@echo ""
	@echo "Preset Rule Sets:"
	@echo "- Classical Counterpoint"
	@echo "- Jazz Improvisation"
	@echo "- Minimalist Composition"
	@echo "- Basic Constraints"

# Help target
help:
	@echo "ClusterEngine Rules Interface System - Build Targets"
	@echo "=================================================="
	@echo "all              - Build library and tests (default)"
	@echo "test             - Run comprehensive test suite"
	@echo "quick-test       - Run quick functionality test"
	@echo "profile          - Run performance profiling"
	@echo "clean            - Remove build artifacts"
	@echo "debug            - Build with debug information"
	@echo "release          - Build optimized release version"
	@echo "analyze          - Run static code analysis"
	@echo "format           - Format source code"
	@echo "docs             - Generate documentation"
	@echo "install-headers  - Install headers for integration"
	@echo "dev-package      - Create development package"
	@echo "integration-ready - Check integration readiness"
	@echo "show-rules       - Show available rule types"
	@echo "help             - Show this help message"
	@echo ""
	@echo "🎵 Musical Constraint Rules System for Real-Time Composition"

# Phony targets
.PHONY: all test quick-test profile clean debug release analyze format docs install-headers dev-package integration-ready show-rules help

# Developer convenience aliases  
dev: debug test
test-perf: release profile
rules-info: show-rules
ready: integration-ready