{
  "configuration": {
    "name": "Multiple Arithmetic Test",
    "description": "Multiple arithmetic constraints working together",
    "num_voices": 1,
    "sequence_length": 4,
    "pitch_range": [60, 75],
    "rhythm_values": [1],
    "time_signature": "4/4"
  },
  "rules": [
    {
      "id": "note_0",
      "rule_id": "note_0",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[0] == 60",
      "description": "First note: C4"
    },
    {
      "id": "note_1",
      "rule_id": "note_1",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[1] == voice[0].pitch[0] + 4",
      "description": "Second note: first + 4"
    },
    {
      "id": "note_2",
      "rule_id": "note_2",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[2] == voice[0].pitch[1] + 3",
      "description": "Third note: second + 3"
    },
    {
      "id": "note_3",
      "rule_id": "note_3",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[3] == voice[0].pitch[0] + 12",
      "description": "Fourth note: first + octave"
    }
  ]
}
