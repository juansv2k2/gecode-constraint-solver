{
  "configuration": {
    "name": "Minimal Wildcard Test",
    "description": "Test if wildcard constraints work at all",
    "num_voices": 2,
    "sequence_length": 3,
    "pitch_range": [60, 65],
    "rhythm_values": [1],
    "time_signature": "4/4"
  },
  "rules": [
    {
      "id": "voice0_60",
      "rule_id": "voice0_60",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[i] == 60",
      "description": "Voice 0 all C4"
    },
    {
      "id": "voice1_62",
      "rule_id": "voice1_62",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[1].pitch[i] == 62",
      "description": "Voice 1 all D4"
    }
  ]
}
