{
  "name": "C Major Stepwise with Parallel Fifths",
  "description": "Voice 0: C major, stepwise, all different. Voice 1: a fifth above.",
  "solution_length": 8,
  "num_voices": 2,
  "backtrack_method": "intelligent",
  "export_path": "tests/output",

  "engine_domains": {
    "engine_0": {
      "type": "rhythm",
      "voice": 0,
      "duration_values": ["1/8"],
      "description": "Voice 0: quarter notes only"
    },
    "engine_1": {
      "type": "pitch",
      "voice": 0,
      "midi_values": [
        60, 62, 64, 65, 67, 69, 71, 72, 74, 76, 77, 79, 81, 83, 84
      ],
      "description": "Voice 0: C major, two octaves"
    },
    "engine_2": {
      "type": "rhythm",
      "voice": 1,
      "duration_values": ["1/4"],
      "description": "Voice 1: quarter notes only"
    },
    "engine_3": {
      "type": "pitch",
      "voice": 1,
      "midi_values": [
        67, 69, 71, 72, 74, 76, 77, 79, 81, 83, 84, 86, 88, 90, 91
      ],
      "description": "Voice 1: C major starting from G4, two octaves"
    },
    "engine_4": {
      "type": "metric",
      "voice": "all",
      "time_signature": ["4/4", "3/4", "6/8"],
      "description": "possible time signatures are 4/4, 3/4 and 6/8"
    }
  },

  "dynamic_rules": [
    {
      "id": "prefer_parallel_fifths",
      "type": "heuristic_energy",
      "wildcard_type": "for_all_positions",
      "expression": "24 - abs((voice[1].pitch[i] - voice[0].pitch[i]) - 10)",
      "mode": "real_heuristic",
      "candidate_voice": 1,
      "weight": 10,
      "priority": 1,
      "direction": "maximize",
      "description": "Prefer voice 1 to stay a perfect fifth above voice 0"
    }
  ],

  "rules": [
    {
      "rule_type": "r-pitches-one-engine",
      "constraint_function": {
        "type": "builtin",
        "function": "all_different",
        "parameters": []
      },
      "indices": [0, 1, 2, 3, 4, 5, 6, 7],
      "target_engines": [1, 3],
      "engine_type": "pitch",
      "enabled": true,
      "priority": 10,
      "description": "Voice 1 and 2: all notes different"
    },

    {
      "id": "stepwise_motion",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_voices",
      "pattern_offsets": [0, 1],
      "target_engines": [1, 3],
      "constraint": "abs(voice[v].pitch[i+1] - voice[v].pitch[i]) <= 2",
      "enabled": true,
      "priority": 9,
      "description": "Voice 0: consecutive notes are a step apart"
    },
    {
      "rule_type": "r-rhythmic-uniformity",
      "constraint_function": {
        "type": "builtin",
        "function": "equal_values",
        "parameters": ["1/8"]
      },
      "indices": [0, 1, 2, 3, 4, 5, 6, 7],
      "target_engine": 0,
      "engine_type": "rhythm",
      "enabled": true,
      "priority": 7,
      "description": "Voice 0: all eighth notes"
    },
    {
      "rule_type": "r-rhythmic-uniformity",
      "constraint_function": {
        "type": "builtin",
        "function": "equal_values",
        "parameters": ["1/4"]
      },
      "indices": [0, 1, 2, 3, 4, 5, 6, 7],
      "target_engine": 2,
      "engine_type": "rhythm",
      "enabled": true,
      "priority": 7,
      "description": "Voice 1: all quarter notes"
    },
    {
      "rule_type": "r-metric-signature",
      "constraint_function": {
        "type": "builtin",
        "function": "equal_values",
        "parameters": ["4/4", "3/4", "6/8"]
      },
      "indices": [0, 2, 4],
      "target_engine": 4,
      "engine_type": "metric",
      "enabled": true,
      "priority": 6,
      "description": "alternating time signatures"
    }
  ],

  "search_options": {
    "random_seed": 0,
    "timeout_ms": 30000,
    "max_solutions": 1,
    "branching": "first_fail"
  },

  "output_options": {
    "export_xml": false,
    "export_png": false,
    "export_midi": false,
    "show_statistics": true,
    "include_analysis": true
  }
}
