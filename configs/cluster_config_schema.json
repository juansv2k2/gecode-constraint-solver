{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Voice-First Musical Constraint Configuration",
  "description": "User-facing JSON configuration for musical constraint solving with contiguous voices, optional meter, voice-based rule targets, and dynamic heuristic rules.",
  "type": "object",
  "required": ["solution_length", "num_voices", "voices"],
  "properties": {
    "solution_length": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "description": "Number of event slots per voice."
    },
    "score_length": {
      "type": "string",
      "description": "Optional total score length using q-based notation, for example 10q or 36q."
    },
    "num_voices": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Number of contiguous voices. This must match the length of voices when voices is an array."
    },
    "voices": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/voiceDomain"
          }
        },
        {
          "type": "object",
          "description": "Alternative object form. Keys must be contiguous numeric strings starting at 0.",
          "patternProperties": {
            "^[0-9]+$": {
              "$ref": "#/definitions/voiceDomain"
            }
          },
          "additionalProperties": false
        }
      ],
      "description": "Contiguous voice definitions. Array form is preferred because ordering is explicit."
    },
    "meter": {
      "type": "object",
      "description": "Optional global metric domain. Metric targeting is implicit for metric rules.",
      "properties": {
        "time_signatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[0-9]+/[0-9]+$"
          }
        },
        "tuplets": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "beat_divisions": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["time_signatures"]
    },
    "rules": {
      "type": "array",
      "description": "Voice-first built-in rules. Do not use target_engine or target_engines in user-facing configs.",
      "items": {
        "$ref": "#/definitions/rule"
      }
    },
    "dynamic_rules": {
      "type": "array",
      "description": "Optional expression-based hard constraints and heuristics.",
      "items": {
        "type": "object"
      }
    },
    "search_options": {
      "type": "object",
      "description": "Search configuration options.",
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["dfs"]
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "max_solutions": {
          "type": "integer"
        },
        "random_seed": {
          "type": "integer",
          "minimum": 0
        },
        "branching": {
          "type": "string",
          "enum": ["first_fail", "input_order"]
        },
        "value_order": {
          "type": "string",
          "enum": ["min", "random", "heuristic"]
        },
        "restart_policy": {
          "type": "string",
          "enum": ["none", "luby"]
        },
        "enable_metric_engine": {
          "type": "boolean",
          "default": false
        },
        "require_exact_score_length": {
          "type": "boolean",
          "default": false
        },
        "heuristic_top_k": {
          "type": "integer",
          "minimum": 0
        },
        "heuristic_trace": {
          "type": "boolean"
        }
      }
    },
    "output_options": {
      "type": "object",
      "description": "Optional export and presentation settings.",
      "properties": {
        "export_path": {
          "type": "string"
        },
        "export_filename": {
          "type": "string"
        },
        "export_json": {
          "type": "boolean"
        },
        "export_txt": {
          "type": "boolean"
        },
        "export_xml": {
          "type": "boolean"
        },
        "export_png": {
          "type": "boolean"
        },
        "export_midi": {
          "type": "boolean"
        },
        "show_statistics": {
          "type": "boolean"
        },
        "include_analysis": {
          "type": "boolean"
        }
      }
    }
  },
  "definitions": {
    "voiceDomain": {
      "type": "object",
      "properties": {
        "rhythm": {
          "oneOf": [
            {
              "$ref": "#/definitions/rhythmDomainObject"
            },
            {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  }
                ]
              }
            }
          ]
        },
        "pitch": {
          "oneOf": [
            {
              "$ref": "#/definitions/pitchDomainObject"
            },
            {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          ]
        }
      },
      "required": ["rhythm", "pitch"],
      "additionalProperties": false
    },
    "rhythmDomainObject": {
      "type": "object",
      "properties": {
        "duration_values": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["duration_values"],
      "additionalProperties": false
    },
    "pitchDomainObject": {
      "type": "object",
      "properties": {
        "midi_values": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["midi_values"],
      "additionalProperties": false
    },
    "constraintFunction": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "function": {
          "type": "string"
        },
        "parameters": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "number"
              },
              {
                "type": "string"
              }
            ]
          }
        }
      },
      "required": ["type", "function"],
      "additionalProperties": true
    },
    "rule": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "rule_type": {
          "type": "string",
          "enum": [
            "r-pitches-one-engine",
            "r-rhythmic-uniformity",
            "r-cross-voice-no-unisons",
            "r-metric-signature",
            "r-pitches-all-different",
            "r-twelve-tone-voice1",
            "r-palindrome-voice",
            "r-palindrome-voice2"
          ]
        },
        "constraint_function": {
          "$ref": "#/definitions/constraintFunction"
        },
        "indices": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "timepoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target_voice": {
          "type": "integer",
          "minimum": 0,
          "description": "Single voice target for pitch or rhythm rules."
        },
        "target_voices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Multiple voice targets for cross-voice rules."
        },
        "target_component": {
          "type": "string",
          "enum": ["pitch", "rhythm"],
          "description": "Required for non-metric built-in rules."
        },
        "enabled": {
          "type": "boolean"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["rule_type", "constraint_function"],
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "rule_type": {
                "const": "r-metric-signature"
              }
            },
            "required": ["rule_type"]
          },
          "then": {
            "required": ["timepoints"]
          },
          "else": {
            "required": ["indices", "target_component"],
            "oneOf": [
              {
                "required": ["target_voice"]
              },
              {
                "required": ["target_voices"]
              }
            ],
            "not": {
              "anyOf": [
                {
                  "required": ["target_engine"]
                },
                {
                  "required": ["target_engines"]
                }
              ]
            }
          }
        }
      ]
    }
  }
}
