{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cluster Engine Configuration Schema",
  "description": "JSON configuration format for musical constraint solving that mirrors the original Lisp cluster engine interface",

  "type": "object",
  "required": [
    "solution_length",
    "num_voices",
    "backtrack_method",
    "rules",
    "domains"
  ],

  "properties": {
    "solution_length": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "description": "Number of variables in the solution (equivalent to first argument in Lisp)"
    },

    "num_voices": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Number of voices (determines engine count: 2*voices + 1)"
    },

    "backtrack_method": {
      "type": "string",
      "enum": ["chronological", "intelligent", "musical", "minimal"],
      "description": "Backtracking strategy (equivalent to second argument in Lisp)"
    },

    "rules": {
      "type": "array",
      "description": "List of musical constraint rules (equivalent to rule list in Lisp)",
      "items": {
        "type": "object",
        "required": ["rule_type", "constraint_function", "indices"],
        "properties": {
          "rule_type": {
            "type": "string",
            "enum": [
              "r-pitches-one-voice",
              "r-index-pitches-one-voice",
              "r-chords",
              "r-jbs-one-voice",
              "r-metric-hierarchy",
              "r-rhythm-hierarchy",
              "r-pitches-two-voices",
              "r-rhythms-one-voice",
              "r-custom"
            ],
            "description": "Type of rule (equivalent to ce::r-pitches-one-voice etc.)"
          },

          "constraint_function": {
            "type": "object",
            "description": "The actual constraint logic (equivalent to lambda function)",
            "oneOf": [
              {
                "properties": {
                  "type": "builtin",
                  "function": {
                    "type": "string",
                    "enum": [
                      "not_equal",
                      "equal",
                      "less_than",
                      "greater_than",
                      "interval_size",
                      "consonant_interval",
                      "stepwise",
                      "jump_resolution"
                    ]
                  },
                  "parameters": {
                    "type": "array",
                    "items": { "type": "number" }
                  }
                }
              },
              {
                "properties": {
                  "type": "lambda",
                  "variables": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "expression": {
                    "type": "string",
                    "description": "Mathematical expression using variables"
                  }
                }
              }
            ]
          },

          "indices": {
            "type": "array",
            "description": "Variable indices this rule applies to (equivalent to quote sections)",
            "items": { "type": "integer" }
          },

          "voice": {
            "type": "integer",
            "minimum": 0,
            "description": "Which voice this rule applies to (if applicable)"
          },

          "engine_type": {
            "type": "string",
            "enum": ["rhythm", "pitch", "metric"],
            "description": "Which type of engine this rule targets"
          },

          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Whether this rule is active"
          },

          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "default": 5,
            "description": "Rule application priority"
          }
        }
      }
    },

    "domains": {
      "type": "object",
      "required": ["metric_domain", "voice_domains"],
      "description": "Domain definitions for each engine type",

      "properties": {
        "metric_domain": {
          "type": "object",
          "description": "Global metric domain (engine N, where N = 2*voices)",
          "required": ["time_signatures", "subdivisions"],
          "properties": {
            "time_signatures": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "integer" },
                "minItems": 2,
                "maxItems": 2
              },
              "examples": [
                [
                  [4, 4],
                  [3, 4],
                  [2, 4],
                  [5, 8],
                  [7, 8]
                ]
              ]
            },
            "subdivisions": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "integer" }
              },
              "examples": [
                [
                  [1, 2, 3, 4, 6],
                  [1, 2, 3, 4, 6]
                ]
              ]
            },
            "beat_structures": {
              "type": "array",
              "description": "Optional beat hierarchy structures"
            }
          }
        },

        "voice_domains": {
          "type": "array",
          "description": "Domains for each voice (rhythm and pitch engines)",
          "items": {
            "type": "object",
            "required": ["rhythm_domain", "pitch_domain"],
            "properties": {
              "voice_index": {
                "type": "integer",
                "minimum": 0
              },
              "rhythm_domain": {
                "type": "array",
                "description": "Rhythmic values (fractions as [numerator, denominator])",
                "items": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "examples": [
                  [
                    [1, 12],
                    [1, 24],
                    [1, 16],
                    [1, 8],
                    [1, 4],
                    [1, 2]
                  ]
                ]
              },
              "pitch_domain": {
                "type": "array",
                "description": "Available pitch values (MIDI numbers)",
                "items": { "type": "integer" },
                "examples": [
                  [60, 61, 62, 63, 64, 65, 66, 67, 68, 69, 70, 71, 72]
                ]
              }
            }
          }
        }
      }
    },

    "search_config": {
      "type": "object",
      "description": "Additional search configuration options",
      "properties": {
        "max_iterations": {
          "type": "integer",
          "default": 10000
        },
        "timeout_seconds": {
          "type": "number",
          "default": 30.0
        },
        "enable_heuristics": {
          "type": "boolean",
          "default": true
        },
        "debug_mode": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
