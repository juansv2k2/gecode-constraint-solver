{
  "name": "Simple Palindrome Test",
  "description": "Simpler test: First voice all different notes, second voice is palindrome of first.",
  "solution_length": 4,
  "num_voices": 2,
  "num_engines": 5,
  "engine_architecture": {
    "voice_0": { "rhythm_engine": 0, "pitch_engine": 1 },
    "voice_1": { "rhythm_engine": 2, "pitch_engine": 3 },
    "metric_engine": 4
  },
  "backtrack_method": "intelligent",
  "export_path": "tests/output",

  "rules": [
    {
      "rule_type": "r-pitches-one-engine",
      "constraint_function": {
        "type": "builtin",
        "function": "all_different",
        "parameters": []
      },
      "indices": [0, 1, 2, 3],
      "target_engine": 1,
      "engine_type": "pitch",
      "enabled": true,
      "priority": 10,
      "description": "Voice 0: All 4 pitch classes different"
    },

    {
      "rule_type": "r-palindrome-voice",
      "constraint_function": {
        "type": "custom",
        "function": "palindrome_of_engine",
        "parameters": [1, 3]
      },
      "indices": [0, 1, 2, 3],
      "target_engine": -1,
      "target_engines": [1, 3],
      "engine_type": "pitch",
      "enabled": true,
      "priority": 8,
      "description": "Voice 1 is exact palindrome of Voice 0"
    },

    {
      "rule_type": "r-rhythmic-uniformity",
      "constraint_function": {
        "type": "builtin",
        "function": "equal_values",
        "parameters": [4]
      },
      "indices": [0, 1, 2, 3],
      "target_engine": 0,
      "engine_type": "rhythm",
      "enabled": true,
      "priority": 7,
      "description": "All quarter notes"
    },

    {
      "rule_type": "r-rhythmic-uniformity",
      "constraint_function": {
        "type": "builtin",
        "function": "equal_values",
        "parameters": [4]
      },
      "indices": [0, 1, 2, 3],
      "target_engine": 2,
      "engine_type": "rhythm",
      "enabled": true,
      "priority": 7,
      "description": "All quarter notes"
    }
  ],

  "search_config": {
    "max_solutions": 1,
    "timeout_ms": 5000
  },

  "domains": [
    {
      "domain_type": "pitch",
      "min_value": 60,
      "max_value": 71,
      "name": "C4-B4"
    }
  ]
}
