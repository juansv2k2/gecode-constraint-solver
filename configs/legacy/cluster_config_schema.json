{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Voice-First Musical Constraint Configuration",
  "description": "User-facing JSON configuration for musical constraint solving with contiguous voices, optional meter, voice-based rule targets, and dynamic heuristic rules.",
  "type": "object",
  "required": ["solution_length", "num_voices"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Optional human-readable name for this configuration."
    },
    "description": {
      "type": "string",
      "description": "Optional description of what this configuration does."
    },
    "solution_length": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "description": "Number of event slots per voice."
    },
    "score_length": {
      "type": "string",
      "description": "Optional total score length using q-based notation, for example 10q or 36q."
    },
    "num_voices": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Number of contiguous voices. This must match the length of voices when voices is an array."
    },
    "global_domain": {
      "type": "object",
      "description": "Optional shared pitch and/or rhythm domain used as a fallback for any voice that does not declare its own. The voices array may be shorter than num_voices (or omitted) when global_domain covers remaining voices.",
      "properties": {
        "pitch": {
          "$ref": "#/definitions/pitchDomainObject"
        },
        "rhythm": {
          "$ref": "#/definitions/rhythmDomainObject"
        }
      },
      "additionalProperties": false
    },
    "voices": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/voiceDomain"
          }
        },
        {
          "type": "object",
          "description": "Alternative object form. Keys must be contiguous numeric strings starting at 0.",
          "patternProperties": {
            "^[0-9]+$": {
              "$ref": "#/definitions/voiceDomain"
            }
          },
          "additionalProperties": false
        }
      ],
      "description": "Contiguous voice definitions. Array form is preferred because ordering is explicit. Can be omitted when global_domain covers all voices."
    },
    "meter": {
      "type": "object",
      "description": "Optional global metric domain. Metric targeting is implicit for metric rules.",
      "properties": {
        "time_signatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[0-9]+/[0-9]+$"
          }
        },
        "tuplets": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "beat_divisions": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["time_signatures"]
    },
    "rules": {
      "type": "array",
      "description": "Voice-first built-in rules. Do not use target_engine or target_engines in user-facing configs.",
      "items": {
        "$ref": "#/definitions/rule"
      }
    },
    "dynamic_rules": {
      "type": "array",
      "description": "Optional expression-based hard constraints and heuristics.",
      "items": {
        "type": "object"
      }
    },
    "search_options": {
      "type": "object",
      "description": "Search configuration options.",
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["dfs"]
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "max_solutions": {
          "type": "integer",
          "description": "Maximum number of solutions to find. Alias: 'solutions'."
        },
        "solutions": {
          "type": "integer",
          "description": "Alias for max_solutions. Maximum number of solutions to find."
        },
        "random_seed": {
          "type": "integer",
          "minimum": 0
        },
        "branching": {
          "type": "string",
          "enum": ["first_fail", "input_order"]
        },
        "value_order": {
          "type": "string",
          "enum": ["min", "random", "heuristic"]
        },
        "restart_policy": {
          "type": "string",
          "enum": ["none", "luby"]
        },
        "enable_metric_engine": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "integer", "minimum": 0, "maximum": 1 }
          ],
          "description": "Enable the metric/time-signature engine. Accepts true/false or 1/0.",
          "default": false
        },
        "require_exact_score_length": {
          "type": "boolean",
          "default": false
        },
        "heuristic_top_k": {
          "type": "integer",
          "minimum": 0
        },
        "heuristic_trace": {
          "type": "boolean"
        }
      }
    },
    "output_options": {
      "type": "object",
      "description": "Optional export and presentation settings.",
      "properties": {
        "export_path": {
          "type": "string"
        },
        "export_filename": {
          "type": "string"
        },
        "export_json": { "$ref": "#/definitions/booleanOrInt" },
        "export_txt": { "$ref": "#/definitions/booleanOrInt" },
        "export_xml": { "$ref": "#/definitions/booleanOrInt" },
        "export_png": { "$ref": "#/definitions/booleanOrInt" },
        "export_midi": { "$ref": "#/definitions/booleanOrInt" },
        "show_statistics": { "$ref": "#/definitions/booleanOrInt" },
        "include_analysis": { "$ref": "#/definitions/booleanOrInt" }
      }
    }
  },
  "definitions": {
    "voiceDomain": {
      "type": "object",
      "properties": {
        "voice": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional explicit voice index for non-positional targeting. When omitted the position in the voices array determines the voice index."
        },
        "rhythm": {
          "oneOf": [
            {
              "$ref": "#/definitions/rhythmDomainObject"
            },
            {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  }
                ]
              }
            }
          ]
        },
        "pitch": {
          "oneOf": [
            {
              "$ref": "#/definitions/pitchDomainObject"
            },
            {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          ]
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "rhythmDomainObject": {
      "type": "object",
      "properties": {
        "duration_values": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["duration_values"],
      "additionalProperties": false
    },
    "pitchDomainObject": {
      "type": "object",
      "properties": {
        "midi_values": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["midi_values"],
      "additionalProperties": false
    },
    "booleanOrInt": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "integer", "minimum": 0, "maximum": 1 }
      ],
      "description": "Accepts true/false or 1/0."
    },
    "constraintFunction": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "function": {
          "type": "string"
        },
        "parameters": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "number"
              },
              {
                "type": "string"
              }
            ]
          }
        }
      },
      "required": ["type", "function"],
      "additionalProperties": true
    },
    "rule": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "rule_type": {
          "type": "string",
          "description": "The rule type identifier.",
          "enum": [
            "r-one-voice",
            "r-pitches-one-engine",
            "r-pitches-one-voice",
            "r-index-pitches-one-voice",
            "r-uniformity",
            "r-cross-voice-no-unisons",
            "r-cross-voice-retrograde-inversion",
            "r-time-signature",
            "r-metric-hierarchy",
            "r-rhythm-rhythm",
            "r-pitch-pitch",
            "r-pitches-all-different",
            "r-twelve-tone-voice1",
            "r-palindrome-voice",
            "r-palindrome-voice2",
            "r-perfect-fifth-intervals",
            "r-timepoint-relationship",
            "wildcard_constraint"
          ]
        },
        "constraint_function": {
          "$ref": "#/definitions/constraintFunction"
        },
        "constraint": {
          "type": "string",
          "description": "Shorthand for builtin function name. Equivalent to constraint_function.function with type=builtin."
        },
        "parameters": {
          "description": "Optional shorthand alias for constraint_function.parameters when using constraint shorthand.",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "string"
                  }
                ]
              }
            },
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "indices": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "timepoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target_voices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Multiple voice targets for cross-voice rules."
        },
        "target_component": {
          "type": "string",
          "enum": ["pitch", "rhythm", "metric"],
          "description": "Required for non-metric built-in rules."
        },
        "bar_pattern_type": {
          "type": "string",
          "enum": ["fixed", "repeating", "random", "weighted"],
          "description": "For r-time-signature rules: pattern expansion type. 'fixed' uses exact pattern; 'repeating' loops pattern to fill score; 'random' picks randomly; 'weighted' samples by probability."
        },
        "bar_pattern": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]+/[0-9]+$"
          },
          "description": "For r-time-signature rules: list of time signatures (e.g., ['4/4', '3/4'])."
        },
        "bar_pattern_count": {
          "type": "integer",
          "minimum": 1,
          "description": "For 'random' or 'weighted' patterns: how many bars to generate."
        },
        "bar_pattern_repetitions": {
          "type": "integer",
          "minimum": 0,
          "description": "For 'repeating' pattern: explicit repetition count. If 0, calculated automatically to fill score."
        },
        "allow_cross_barline": {
          "$ref": "#/definitions/booleanOrInt",
          "description": "For r-time-signature bar patterns: if true, durations may carry across bar boundaries; if false, each bar is filled strictly."
        },
        "bar_pattern_distribution": {
          "type": "object",
          "description": "For 'weighted' pattern: probability distribution. Keys are time signatures, values are probabilities (sum should be ~1.0).",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "enabled": { "$ref": "#/definitions/booleanOrInt" },
        "stride": {
          "type": "integer",
          "minimum": 1,
          "description": "Apply this rule every N positions starting from offset. Used by r-rhythm-rhythm and r-pitch-pitch. When set, takes precedence over indices."
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "description": "Starting position for stride-based application. Default 0."
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["rule_type"],
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "rule_type": {
                "const": "r-time-signature"
              }
            },
            "required": ["rule_type"]
          },
          "then": {},
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": ["target_engine"]
                },
                {
                  "required": ["target_engines"]
                }
              ]
            }
          }
        }
      ]
    }
  }
}
