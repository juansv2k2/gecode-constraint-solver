{
  "name": "Simple Palindrome Test",
  "description": "Simpler test: First voice all different notes, second voice is palindrome of first.",
  "solution_length": 4,
  "num_voices": 2,
  "rules": [
    {
      "rule_type": "r-pitches-one-engine",
      "constraint_function": {
        "type": "builtin",
        "function": "all_different",
        "parameters": []
      },
      "indices": [0, 1, 2, 3],
      "engine_type": "pitch",
      "enabled": true,
      "priority": 10,
      "description": "Voice 0: All 4 pitch classes different",
      "target_voices": [0],
      "target_component": "pitch"
    },
    {
      "rule_type": "r-palindrome-voice",
      "constraint_function": {
        "type": "custom",
        "function": "palindrome_of_engine",
        "parameters": [1, 3]
      },
      "indices": [0, 1, 2, 3],
      "engine_type": "pitch",
      "enabled": true,
      "priority": 8,
      "description": "Voice 1 is exact palindrome of Voice 0",
      "target_voices": [0, 1],
      "target_component": "pitch"
    },
    {
      "rule_type": "r-uniformity",
      "constraint_function": {
        "type": "builtin",
        "function": "equal_values",
        "parameters": ["1/4"]
      },
      "indices": [0, 1, 2, 3],
      "engine_type": "rhythm",
      "enabled": true,
      "priority": 7,
      "description": "All quarter notes",
      "target_voices": [0],
      "target_component": "rhythm"
    },
    {
      "rule_type": "r-uniformity",
      "constraint_function": {
        "type": "builtin",
        "function": "equal_values",
        "parameters": ["1/4"]
      },
      "indices": [0, 1, 2, 3],
      "engine_type": "rhythm",
      "enabled": true,
      "priority": 7,
      "description": "All quarter notes",
      "target_voices": [1],
      "target_component": "rhythm"
    }
  ],
  "search_config": {
    "max_solutions": 1,
    "timeout_ms": 5000
  },
  "output_options": {
    "export_path": "tests/output"
  },
  "search_options": {
    "branching": "first_fail"
  }
}
