{
  "configuration": {
    "name": "Simple Arithmetic Test",
    "description": "Test arithmetic with just 3 notes",
    "num_voices": 1,
    "sequence_length": 3,
    "pitch_range": [60, 70],
    "rhythm_values": [1],
    "time_signature": "4/4"
  },
  "rules": [
    {
      "id": "starts_c4",
      "rule_id": "starts_c4",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[0] == 60",
      "description": "Start with C4"
    },
    {
      "id": "simple_plus3",
      "rule_id": "simple_plus3",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "sliding_window",
      "pattern_offsets": [0, 1],
      "constraint": "voice[v].pitch[i+1] == voice[v].pitch[i] + 3",
      "description": "Each next note +3 semitones"
    }
  ]
}
