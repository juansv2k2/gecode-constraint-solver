{
  "configuration": {
    "name": "Extended Range Test",
    "num_voices": 2,
    "sequence_length": 3,
    "export_path": "tests/output"
  },
  "rules": [
    {
      "id": "voice1_c4",
      "rule_id": "voice1_c4",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[0].pitch[0] == 60",
      "description": "Voice 1 starts C4"
    },
    {
      "id": "voice2_below",
      "rule_id": "voice2_below",
      "rule_type": "wildcard_constraint",
      "wildcard_type": "for_all_positions",
      "constraint": "voice[1].pitch[i] == voice[0].pitch[i] - 7",
      "description": "Voice 2 is 7 semitones below voice 1"
    }
  ]
}
