{
  "description": "4-voice harmonic consonance study. Quarter-note grid, MIDI 48-72. Perfect consonances (unison/4th/5th/octave) on beats 1 and 3; imperfect consonances (3rds/6ths) on beats 2 and 4.",

  "num_voices": 4,
  "solution_length": 24,

  "meter": {
    "time_signatures": ["4/4"],
    "beat_divisions": [2, 4]
  },

  "voices": [
