{
  "name": "Simple Retrograde Inversion Test",
  "description": "Basic test of retrograde inversion constraint with few notes",
  "solution_length": 6,
  "num_voices": 2,
  "num_engines": 5,
  "engine_architecture": {
    "voice_0": { "rhythm_engine": 0, "pitch_engine": 1 },
    "voice_1": { "rhythm_engine": 2, "pitch_engine": 3 },
    "metric_engine": 4
  },
  "backtrack_method": "intelligent",
  "export_path": "tests/output",

  "rules": [
    {
      "rule_type": "r-cross-voice-retrograde-inversion",
      "constraint_function": {
        "type": "builtin",
        "function": "retrograde_inversion_relationship",
        "parameters": [65]
      },
      "indices": [0, 1, 2],
      "target_engine": 3,
      "engine_type": "cross-voice",
      "enabled": true,
      "priority": 10,
      "description": "Voice 2 is retrograde inversion of Voice 1 around F4 (65)"
    }
  ],

  "domains": [
    {
      "engine_id": 0,
      "type": "rhythm",
      "values": [4, 4, 4],
      "description": "Voice 1 rhythm: All quarter notes"
    },
    {
      "engine_id": 1,
      "type": "pitch",
      "values": [60, 62, 64, 66, 68, 70],
      "description": "Voice 1 pitch: Even semitones only (C4, D4, E4, F#4, G#4, A#4)"
    },
    {
      "engine_id": 2,
      "type": "rhythm",
      "values": [4, 4, 4],
      "description": "Voice 2 rhythm: All quarter notes"
    },
    {
      "engine_id": 3,
      "type": "pitch",
      "values": [60, 62, 64, 66, 68, 70],
      "description": "Voice 2 pitch: Even semitones - will be constrained by retrograde inversion"
    },
    {
      "engine_id": 4,
      "type": "metric",
      "values": [9],
      "description": "Metric: 3/4 time signature"
    }
  ],

  "search_strategy": {
    "max_time_ms": 10000,
    "max_solutions": 1,
    "randomize_search": false,
    "variable_ordering": "sequential",
    "value_ordering": "min"
  },

  "output_options": {
    "format": "both",
    "include_analysis": true,
    "export_midi": false,
    "export_xml": true,
    "export_png": true,
    "show_statistics": true,
    "show_intervals": true,
    "show_voice_details": true
  },

  "display_options": {
    "show_midi_numbers": true,
    "show_note_names": true,
    "show_intervals": true,
    "group_by_voice": true
  }
}
