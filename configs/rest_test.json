{
  "name": "Rest Support Test",
  "description": "Single voice, 4 positions, mix of quarter notes and quarter rests. All note pitches distinct.",
  "solution_length": 4,
  "num_voices": 1,
  "backtrack_method": "intelligent",

  "engine_domains": {
    "engine_0": {
      "type": "pitch",
      "voice": 0,
      "midi_values": [60, 62, 64, 65],
      "description": "Voice 0: C D E F"
    },
    "engine_1": {
      "type": "rhythm",
      "voice": 0,
      "duration_values": ["1/4", "-1/4"],
      "description": "Voice 0: quarter notes and quarter rests"
    }
  },

  "rules": [
    {
      "id": "r-pitches-all-different",
      "function": "all_different",
      "voice": 0,
      "description": "All note pitches distinct (rests have sentinel -1, excluded by AllDifferent on notes)"
    }
  ],

  "search_options": {
    "timeout_ms": 5000,
    "max_solutions": 5,
    "branching": "first_fail"
  },

  "output_options": {
    "export_path": "output",
    "export_json": true,
    "export_txt": true,
    "export_xml": false,
    "export_png": false,
    "export_midi": false
  }
}
