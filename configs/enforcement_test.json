{
  "name": "Constraint Enforcement Test",
  "description": "Force specific values to prove constraints work",
  "solution_length": 4,
  "num_voices": 2,
  "backtrack_method": "intelligent",
  "export_path": "tests/output",

  "dynamic_rules": [
    {
      "id": "force_different_notes",
      "type": "basic_constraint",
      "expression": {
        "operator": "!=",
        "left": "voice[0].pitch[1]",
        "right": "voice[0].pitch[0]"
      },
      "mode": "constraint",
      "description": "Voice 1: Second note must be different from first"
    },
    {
      "id": "force_ascending",
      "type": "basic_constraint",
      "expression": {
        "operator": ">",
        "left": "voice[0].pitch[1]",
        "right": "voice[0].pitch[0]"
      },
      "mode": "constraint",
      "description": "Voice 1: Second note must be higher than first"
    },
    {
      "id": "start_C4",
      "type": "basic_constraint",
      "expression": {
        "operator": "==",
        "left": "voice[0].pitch[0]",
        "right": { "value": 60 }
      },
      "mode": "constraint",
      "description": "Voice 1: Start on C4"
    },
    {
      "id": "stepwise_motion",
      "type": "basic_constraint",
      "expression": {
        "operator": "<=",
        "left": {
          "function": "abs",
          "args": [
            {
              "operator": "-",
              "left": "voice[0].pitch[1]",
              "right": "voice[0].pitch[0]"
            }
          ]
        },
        "right": { "value": 3 }
      },
      "mode": "constraint",
      "description": "Voice 1: Stepwise motion (max 3 semitones)"
    }
  ]
}
